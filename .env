# =========================================================
# FISH! APPRAISER ENGINE - ENVIRONMENT CONFIG
# =========================================================

# --- ENVIRONMENT MODE ---
# 'development' = Hot-swapping enabled. Caching is entirely disabled for all files.
# 'production'  = Caching enabled for static assets (images, js). CSS, JSON, and Lang bypass cache.
ENV=development

# --- NETWORK & HOSTING ---
# 80 for standard HTTP, 443 for standard HTTPS, or 8080 for local dev
PORT=8080
HOST=localhost

# --- ENGINE CONFIGURATION ---
# Base language for the server to inject into the frontend if the user has no saved preference.
# Options: en, jp
DEFAULT_LANG=en

# Cache duration for static assets (images, js) in seconds.
# 86400 = 1 Day. (Note: Ignored completely if ENV=development)
CACHE_MAX_AGE=86400

# --- SECURITY (SSL / HTTPS) ---
# Set to 'true' if deploying to a production server that requires certificates.
USE_SSL=false

# File paths to your SSL certificates (Relative to server.js)
# Only required if USE_SSL is set to true.
SSL_KEY=./certs/privkey.pem
SSL_CERT=./certs/fullchain.pem