# --- Network Configuration ---
PORT=8080
HOST=localhost

# --- Engine Settings ---
CACHE_MAX_AGE=86400

# --- Production Security (Optional) ---
# Set to 'true' to enable HTTPS for live web deployment
USE_SSL=false
SSL_KEY=./certs/privkey.pem
SSL_CERT=./certs/fullchain.pem